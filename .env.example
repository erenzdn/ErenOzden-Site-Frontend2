# ==============================================================================
# ERENOZDEN-FRONTEND-2 - Environment Variables Örneği (.env.example)
# ==============================================================================
#
# Bu dosya, projenin çalışması için gereken ortam değişkenlerinin şablonudur.
# Yerel geliştirme için bu dosyayı kopyalayıp ".env.local" adıyla kaydedin:
# cp .env.example .env.local
#
# Next.js'te ortam değişkenleri okuma önceliği:
# 1. Geliştirmede (npm run dev): .env.local dosyası okunur.
# 2. Canlı ortamda (production build): Sunucu ortam değişkenleri veya .env.production okunur.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. STRAPI BACKEND URL AYARLARI (Tek Değişken ile Yönetim)
# ------------------------------------------------------------------------------
# API istekleri ve görsel çözümlemeleri bu URL üzerinden yönetilir.
# Sonuna eğik çizgi (/) koymayın; helper fonksiyonumuz trailing slash'leri otomatik temizler.

# LOCAL GELİŞTİRME (Yerel Strapi — Cursor 1337 portunu işgal edebilir, farklı port kullanın)
# NEXT_PUBLIC_STRAPI_URL=http://127.0.0.1:1337

# PRODUCTION (Canlı Strapi API)
NEXT_PUBLIC_STRAPI_URL=https://api.mehmeterenozden.com


# ------------------------------------------------------------------------------
# 2. STRAPI USERS & PERMISSIONS / AUTH & TOKENS (İsteğe Bağlı)
# ------------------------------------------------------------------------------
# Koleksiyonlarınız Strapi'de "Public" (Herkese Açık) olarak ayarlanmışsa bu değişkene gerek yoktur.
# Eğer API'ye erişim için "API Token" (Read-Only veya Full Access) gerekiyorsa buraya tanımlayın:
# STRAPI_API_TOKEN=your_strapi_read_only_api_token_here
# NEXT_PUBLIC_STRAPI_API_TOKEN=your_strapi_read_only_api_token_here


# ------------------------------------------------------------------------------
# ⚠️ DRAFT & PUBLISH SİSTEMİ NOTU:
# ------------------------------------------------------------------------------
# Strapi'de içerik tipi ayarlarında "Draft and Publish" (Taslak ve Yayınlama) açıksa:
# - Geliştirme (Local) aşamasında içeriklerin API üzerinden frontend'e gelebilmesi için
#   Strapi Admin panelinde o içeriğin "Published" (Yayınlanmış) durumuna getirilmesi gerekir.
# - "Draft" (Taslak) durumundaki içerikler varsayılan (Public) isteklerde görünmez.
# ------------------------------------------------------------------------------
